# ------------------------------------------------------------------------------
# METRAI CALCULUS - ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and adjust variables for your target environment.
# ------------------------------------------------------------------------------

PROJECT_NAME="Metrai Calculus"
ENVIRONMENT="production"  # production, staging, development
DEBUG=false
SECRET_KEY="replace-this-with-a-very-long-and-highly-secure-random-cryptographic-key-for-jwt"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Configuration
# SQLite is used by default. For PostgreSQL, change to:
# postgresql://user:password@host:5432/dbname
DATABASE_URL="sqlite:///./metrai_calculus.db"

# Security & Rate Limiting
ALLOWED_HOSTS="metraicalculus.com,www.metraicalculus.com"
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
CSRF_COOKIE_SECURE=true
SESSION_COOKIE_SECURE=true

# OCR Engine (Local Path to Tesseract - Required for Windows local dev)
# Leave blank on Linux/Docker as it will be loaded from system path
TESSERACT_CMD="C:\\Program Files\\Tesseract-OCR\\tesseract.exe"

# Email Verification & Notifications Setup (Placeholder structure)
SMTP_HOST="smtp.mailgun.org"
SMTP_PORT=587
SMTP_USER="postmaster@mg.metraicalculus.com"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM="Metrai Calculus <noreply@metraicalculus.com>"

# Cache Configuration
CACHE_TTL_SECONDS=300
